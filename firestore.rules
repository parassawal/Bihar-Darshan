rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Stories collection - user generated content
    match /stories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Shops collection - user submitted, admin verified
    match /shops/{shopId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Site content collections - public read, admin write
    match /admins/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /marketplace/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /places/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /districts/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /communities/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /culture/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
