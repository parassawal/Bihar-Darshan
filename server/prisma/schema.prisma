// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model District {
  id                   Int               @id @default(autoincrement())
  name                 String            @unique
  image                String
  tagline              String?
  introduction         String?
  richHistory          String?
  topTouristName       String?
  topTouristDetails    String?
  howToReachAir        String?
  howToReachRail       String?
  howToReachRoad       String?
  whyInTouristList     String[]          // PostgreSQL supports native arrays
  seasonalVisits       SeasonRow[]
  topAttractions       TopAttraction[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model SeasonRow {
  id         Int      @id @default(autoincrement())
  season     String
  months     String
  weather    String
  whyVisit   String
  districtId Int
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
}

model TopAttraction {
  id               Int      @id @default(autoincrement())
  name             String
  image            String
  description      String
  shortDescription String?
  rating           Float?
  bestTime         String?
  districtId       Int
  district         District @relation(fields: [districtId], references: [id], onDelete: Cascade)
}

model CultureItem {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  image       String
  description String
  featured    Boolean  @default(false)
  author      String?  @default("Admin")
  createdAt   DateTime @default(now())
}

model GalleryItem {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String
  category    String
  likes       Int      @default(0)
  views       Int      @default(0)
  comments    Int      @default(0)
  uploadDate  String?
  author      String?  @default("Community")
  createdAt   DateTime @default(now())
}

model PersonalityItem {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  district    String
  description String
  imageUrl    String
  fullBio     String?
  author      String?  @default("Admin")
  createdAt   DateTime @default(now())
}

model JourneySubmission {
  id          String   @id @default(uuid())
  title       String
  description String
  author      String
  duration    String?
  budget      String?
  district    String?
  stops       String[]
  createdAt   DateTime @default(now())
}

model Community {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String
  image       String
  membersCount Int         @default(0)
  discussions Discussion[]
  createdAt   DateTime     @default(now())
}

model Discussion {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  author      String
  likes       Int       @default(0)
  repliesCode Int       @default(0)
  communityId Int
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model ProductItem {
  id           Int      @id @default(autoincrement())
  businessName String
  productName  String
  category     String
  image        String
  images       String[]
  description  String
  address      String?
  website      String?
  mapLink      String?
  contact      String?
  email        String?
  createdAt    DateTime @default(now())
}

model TribeItem {
  id          Int      @id @default(autoincrement())
  hindiName   String
  englishName String
  shortDesc   String
  image       String
  leftTitle   String?
  leftDesc    String?
  rightTitle  String?
  rightDesc   String?
  bottomDesc  String?
  createdAt   DateTime @default(now())
}

model TribalArticle {
  id            String   @id @default(uuid())
  headline      String
  description   String
  image         String
  images        String[]
  author        String
  tribe         String
  publishedDate String
  readTime      Int
  tags          String[]
  location      String
  createdAt     DateTime @default(now())
}

model SiteSettings {
  id                 Int      @id @default(1)
  heroTitle          String   @default("Discover the Soul of")
  heroSubtitle       String   @default("Bihar")
  heroDescription    String   @default("Ancient ruins, sacred temples, breathtaking landscapes, living festivals, authentic cuisines and stories waiting to be explored through immersive storytelling.")
  heroImage          String   @default("")
  statPlaces         String   @default("500+")
  statDistricts      String   @default("38")
  statCulturalSites  String   @default("100+")
  statFestivals      String   @default("50+")
  statTourists       String   @default("1000+")
  footerAbout        String   @default("Bihar Darshan is a digital platform to explore the rich cultural heritage, historical landmarks, and vibrant communities of Bihar.")
}

